# Copie este arquivo para ".env" e preencha os valores locais.
# Nunca compartilhe nem versione o arquivo .env real.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Pasta raiz da estrutura local do TCE.
MPC_TCE_ROOT=E:\TCE

# Opcionais. Se omitidos, serão derivados de MPC_TCE_ROOT.
# MPC_DB_PATH=E:\TCE\Database\BD-MPC.db
# MPC_CONTROLE_PRODUCAO=E:\TCE\Produção\Controle de Produção.xlsx
# MPC_BANCO_PARAGRAFOS=C:\caminho\banco_paragrafos.json

# Segurança e histórico. Se omitidos, usam pastas ao lado do programa.
# MPC_BACKUP_DIR=C:\Dev\backups
# MPC_MODELOS_VERSIONADOS_DIR=C:\Dev\modelos_versionados

# Quantos dias os backups devem ser mantidos. Use 0 para desativar a limpeza automática.
MPC_BACKUP_RETENCAO_DIAS=90

# Intervalo do salvamento automático de recuperação (mínimo interno: 10 s).
MPC_AUTOSAVE_SEGUNDOS=30

# Cria automaticamente uma nova versão somente quando um modelo Word muda.
MPC_VERSIONAR_MODELOS_AUTO=1

# Somente para diagnóstico explícito. O padrão seguro é não limpar o cache.
MPC_CLEAR_PYWIN32_CACHE=0

# Limites de segurança para leitura integral e descompactação.
MPC_MAX_AI_DOCUMENT_MB=50
MPC_MAX_ZIP_MEMBER_MB=100
MPC_MAX_ZIP_TOTAL_MB=500
